# =============================================================================
# Kubernetes Resource Efficiency & Cost Monitor — Discord Bot
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Discord ---
DISCORD_TOKEN=your-bot-token-here
DISCORD_GUILD_ID=123456789012345678
REPORT_CHANNEL_ID=123456789012345678

# --- Prometheus ---
PROMETHEUS_URL=http://prometheus-server.monitoring.svc:9090

# --- OpenCost ---
OPENCOST_URL=http://opencost.opencost.svc:9003

# --- Pricing ---
# Name of the pricing profile file inside config/pricing/
PRICING_PROFILE=default.json

# --- Analysis ---
# Lookback window for PromQL queries (e.g., 1h, 24h, 7d)
LOOKBACK_WINDOW=24h

# --- Scheduler ---
# Day of week for automated weekly report (monday, tuesday, ... sunday)
WEEKLY_REPORT_DAY=monday
# Hour (0-23 UTC) to post the weekly report
WEEKLY_REPORT_HOUR=9

# --- Logging ---
LOG_LEVEL=INFO
